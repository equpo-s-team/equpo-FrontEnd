rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /teams/{teamId} {
      // The team document itself can be read by its members
      allow read: if exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      
      // Tasks subcollection can be read by team members
      match /tasks/{taskId} {
        allow read: if exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
        // Note: write access is guarded by the backend POST/PATCH endpoints.
        // We only allow read directly from Firestore for real-time syncing.
        allow write: if false; 
      }
      
      // Members subcollection can be read by team members
      match /members/{memberId} {
        allow read: if exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
        allow write: if false;
      }
    }
    
    // Fallback rule for tasks written directly to a root collection named after the teamId
    match /{teamId}/{taskId} {
      allow read: if teamId != "teams" && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      allow write: if false;
    }
  }
}
